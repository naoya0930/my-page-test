{
  "name": "my-cloudflare-react-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "workers:dev": "wrangler dev --ip 0.0.0.0 --port 8787",
    "workers:deploy": "wrangler deploy",
    "d1:create": "wrangler d1 create ast_way_db",
    "d1:list": "wrangler d1 list",
    "d1:execute": "wrangler d1 execute ast_way_db --local --command",
    "d1:migrate": "wrangler d1 execute ast_way_db --local --file=./migrations/001_create_tables.sql",
    "d1:migrate:prod": "wrangler d1 execute ast_way_db --file=./migrations/001_create_tables.sql",
    "d1:seed": "wrangler d1 execute ast_way_db --local --persist-to .wrangler --file=./migrations/test_data_v2.sql",
    "d1:reset": "wrangler d1 execute ast_way_db --local --persist-to .wrangler --file=./migrations/001_create_tables.sql && npm run d1:seed",
    "d1:tables": "wrangler d1 execute ast_way_db --local --command=\"SELECT name FROM sqlite_master WHERE type='table';\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.17.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.5",
    "typescript": "^5.6.2",
    "vite": "^7.0.0",
    "wrangler": "^4.101.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-arm64-gnu": "4.62.0",
    "@rollup/rollup-linux-x64-gnu": "4.62.0",
    "@rollup/rollup-darwin-arm64": "4.62.0",
    "@rollup/rollup-darwin-x64": "4.62.0"
  }
}
